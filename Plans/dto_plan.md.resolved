## المرحلة 4: إنشاء ملفات جديدة

---

### [NEW] `DonorMedicalDocumentDto.cs`

```csharp
namespace BloodConnectAPI.Models.DTOs;

/// <summary> DTO لعرض وثيقة طبية </summary>
public class DonorMedicalDocumentDto
{
    public int DocumentID { get; set; }
    public int DonorID { get; set; }
    public string DocumentType { get; set; } = string.Empty;
    public string FilePath { get; set; } = string.Empty;
    public DateTime UploadedAt { get; set; }
    public bool IsVerified { get; set; }
    public string? Notes { get; set; }
}

/// <summary> DTO لرفع وثيقة طبية جديدة (الملف يُرفع عبر IFormFile ويُحفظ في wwwroot) </summary>
public class SubmitMedicalDocumentDto
{
    public int DonorID { get; set; }
    public string DocumentType { get; set; } = string.Empty;  // CBC, HBsAg, HIV, HCV, Syphilis...
    public IFormFile File { get; set; } = null!;               // الملف المرفوع
}

/// <summary> DTO لتحديث حالة وثيقة (تحقق الإدارة) </summary>
public class VerifyMedicalDocumentDto
{
    public bool IsVerified { get; set; }
    public string? Notes { get; set; }
}
```

